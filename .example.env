NEXT_PUBLIC_ENV=
PARTNER_API_BASE_URL=http://localhost:1212

# PubNub keys (chat). Both are public-safe — the per-buyer chat token is what
# grants access. Mint that token via POST /partner/v1/chat/authenticate.
NEXT_PUBLIC_PUBNUB_PUB_KEY=
NEXT_PUBLIC_PUBNUB_SUB_KEY=

# B2B2C hash secret. Used SSR-only to decrypt the `hash_code` query param
# (AES-256-GCM) and recover { partner_id, game_id, item_type_id, currency,
# country_code }. Must NEVER be exposed to the browser.
B2B2C_HASH_CODE=
